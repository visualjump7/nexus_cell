# ═══════════════════════════════════════════════════════════════════════════════
# PROMPT ARMORY — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# SUPABASE
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ─────────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# ─────────────────────────────────────────────────────────────────────────────────
# AI PLATFORMS
# ─────────────────────────────────────────────────────────────────────────────────

# OpenAI (DALL-E 3)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Replicate (Stable Diffusion, Flux, Runway)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# fal.ai (Flux.1, fast inference)
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=...

# Ideogram
# Get from: https://ideogram.ai/api
IDEOGRAM_API_KEY=...

# Leonardo AI
# Get from: https://leonardo.ai/
LEONARDO_API_KEY=...

# Midjourney Proxy (if using third-party service)
# Options: useapi.net, goapi.ai, etc.
MIDJOURNEY_PROXY_URL=https://api.useapi.net
MIDJOURNEY_API_KEY=...

# ─────────────────────────────────────────────────────────────────────────────────
# STRIPE (Payments)
# Get from: https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_YEARLY=price_...

# ─────────────────────────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Prompt Armory

# ─────────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Analytics
# ─────────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
